{
  "manifest_version": 3,
  "name": "Azure DevOps Timesheet",
  "version": "1.0.1",
  "description": "Automacoes de lancamento de horas no Azure DevOps.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://dev.azure.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://dev.azure.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "version_name": "1.0.1 (build 2026.05.12.1)"
}
